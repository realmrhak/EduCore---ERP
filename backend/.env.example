# ──────────────────────────────────────────────────────────────────────────────
# EduCore ERP — Backend Environment Variables
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# For Render deployment, set these in the Environment section of your web service.
# NEVER commit .env files to version control!
# ──────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────

# MongoDB connection string
# Local:   mongodb://localhost:27017/educore
# Atlas:   mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/educore?retryWrites=true&w=majority
MONGODB_URI=

# JWT secret for access tokens (use a long, random string in production)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# ── Authentication ────────────────────────────────────────────────────────────

# JWT refresh token secret (must differ from JWT_SECRET)
JWT_REFRESH_SECRET=

# Token expiry durations
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=7d

# ── Server ────────────────────────────────────────────────────────────────────

NODE_ENV=production
PORT=5000

# ── CORS ──────────────────────────────────────────────────────────────────────

# Comma-separated list of allowed frontend origins
# Vercel frontend URL(s):
CORS_ORIGIN=https://your-app.vercel.app

# For multiple origins:
# CORS_ORIGIN=https://your-app.vercel.app,https://your-app-git-main.vercel.app

# ── Deployment Mode ───────────────────────────────────────────────────────────

# Set to 'true' when frontend and backend are deployed separately (Vercel + Render)
# This disables serving frontend static files from the backend
SPLIT_DEPLOYMENT=true

# ── Super Admin (used during auto-seed) ───────────────────────────────────────

SUPER_ADMIN_EMAIL=admin@educore.edu
SUPER_ADMIN_PASSWORD=ChangeThisStrongPassword123!

# ── Cloudinary (Optional — for file uploads) ──────────────────────────────────

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Redis (Optional — for session caching) ────────────────────────────────────

REDIS_URL=

# ── Database Seed ─────────────────────────────────────────────────────────────

# Set to 'true' to force re-seed the database on next server start
# WARNING: This will delete all existing data!
FORCE_RESEED=false
