# ──────────────────────────────────────────────────────────────────────────────
# EduCore ERP — Frontend Environment Variables
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# For Vercel deployment, set these in Project Settings → Environment Variables.
# NEVER commit .env files to version control!
# ──────────────────────────────────────────────────────────────────────────────

# ── API URL ───────────────────────────────────────────────────────────────────

# Development: Leave empty — Vite proxy handles /api → localhost:5000
# Production (Vercel + Render): Set to your Render backend URL
VITE_API_URL=https://your-backend.onrender.com/api

# ── Notes ─────────────────────────────────────────────────────────────────────
# - VITE_ prefix is required for Vite to expose the variable to the client
# - Changes to .env require a server restart (dev) or rebuild (production)
# - For Vercel: Set VITE_API_URL in the Vercel dashboard, then redeploy
